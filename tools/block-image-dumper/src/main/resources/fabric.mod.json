{
  "schemaVersion": 1,
  "id": "block-image-dumper",
  "version": "${version}",
  "name": "Block Image Dumper",
  "description": "Press F7 in any world to dump every registered item's inventory render to a PNG. Used to generate block images for the shulker-preview data pack.",
  "authors": ["Ethan Arrowood"],
  "license": "MIT",
  "environment": "client",
  "entrypoints": {
    "client": [
      "dev.ethanarrowood.blockdumper.BlockImageDumperMod"
    ]
  },
  "mixins": [
    "block-image-dumper.mixins.json"
  ],
  "dependencies": {
    "fabricloader": ">=0.19.2",
    "minecraft": "~26.1",
    "fabric-api": "*"
  }
}
